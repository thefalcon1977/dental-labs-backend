## Endpoint Decorator Template

Use this as a checklist when adding or updating an endpoint. For a DRY approach, use the section above (reusable dicts or Pydantic error model) so the decorator stays short; the template below shows the full inline shape for reference.

```python
@router.post(
    "/resources",
    response_model=ResourceResponse,
    status_code=status.HTTP_201_CREATED,
    summary="Create resource",
    description=(
        "Create a new resource. "
        "Requires authentication. "
        "Optional: mention idempotency, validation rules, or side effects."
    ),
    responses={
        201: {
            "description": "Resource created successfully",
            "content": {
                "application/json": {
                    "example": {
                        "id": "res-123",
                        "name": "Example",
                        "created_at": "2024-01-15T10:00:00Z",
                    }
                }
            },
        },
        400: {
            "description": "Invalid input",
            "content": {
                "application/json": {
                    "example": {
                        "error": {
                            "message": "Invalid input",
                            "type": "ValidationError",
                            "details": {"field": "name", "reason": "required"},
                        }
                    }
                }
            },
        },
        401: {"description": "Authentication required"},
        404: {
            "description": "Parent resource not found",
            "content": {
                "application/json": {
                    "example": {
                        "error": {
                            "message": "Parent not found: parent-1",
                            "type": "NotFoundError",
                            "details": {"resource": "Parent", "identifier": "parent-1"},
                        }
                    }
                }
            },
        },
        409: {
            "description": "Resource already exists or conflict",
            "content": {
                "application/json": {
                    "example": {
                        "error": {
                            "message": "Resource with this name already exists",
                            "type": "ConflictError",
                            "details": {"field": "name"},
                        }
                    }
                }
            },
        },
        500: {
            "description": "Internal server error",
            "content": {
                "application/json": {
                    "example": {
                        "error": {
                            "message": "An unexpected error occurred",
                            "type": "InternalServerError",
                            "details": {},
                        }
                    }
                }
            },
        },
    },
)
async def create_resource(...):
    ...
```

